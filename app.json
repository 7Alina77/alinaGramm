      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.alinagramm.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "name": "Мой Мессенджер",
      "shortName": "Messenger",
      "lang": "ru",
      "themeColor": "#007AFF",
      "backgroundColor": "#ffffff"
    },
    "extra": {
      "eas": {
        "projectId": "b7888612-c709-4d54-a271-adcf0d2586c6"
      }
    }
  }

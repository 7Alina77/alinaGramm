{
  "expo": {
    "name": "alinaGramm",
    "slug": "alinagramm-hge9fw",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": ["ios", "android", "web"],
    "icon": "./assets/icon.png",
